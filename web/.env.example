# ==============================================================================
# PRODUCTION: Firebase Configuration
# ==============================================================================
# For local development without cloud dependencies, use .env.example.emulator
# See docs/setup/production-setup.md for full setup instructions

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Base URL for metadata and OpenGraph
NEXT_PUBLIC_BASE_URL=https://oboapp.online

# ==============================================================================
# OPTIONAL SETTINGS
# ==============================================================================

# Locality identifier (required, no default)
# NEXT_PUBLIC_LOCALITY=bg.sofia

# Google Analytics Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry DSN for error monitoring (optional — omit to disable Sentry entirely)
# Used by both the browser client and server-side API routes.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Firebase Cloud Messaging VAPID Key (for push notifications)
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# Firebase Admin SDK Service Account (for API routes and backend)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Firebase Database ID (leave unset to use default database)
# NEXT_PUBLIC_FIREBASE_DATABASE_ID=oboapp-test

# Message Relevance Period (in days)
MESSAGE_RELEVANCE_DAYS=7

# Public API Keys (comma-separated list of static API keys for /api/v1 endpoints — optional fast path)
# Clients must send their key via the X-Api-Key request header.
# All clients (including YSM) should use self-service key management via Settings instead.
# Example: PUBLIC_API_KEYS=key-abc123,key-xyz789
# PUBLIC_API_KEYS=

# Public API Host (when set, /api/v1/* requests are 308-redirected to this host)
# Set this once the standalone API is deployed to redirect existing clients.
# Example: PUBLIC_API_HOST=https://api.oboapp.online
# PUBLIC_API_HOST=

# GCS bucket for shared data files (geocode cache reports, air quality readings).
# Required for the /geocode-cache admin page and the /air-quality monitoring page in production.
# Uses FIREBASE_SERVICE_ACCOUNT_KEY when set; otherwise falls back to ADC.
# GCS_GENERIC_BUCKET=your-project-generic-bucket

# Local filesystem path for readings in development (default: ./tmp/air-quality).
# Populate by running the air-quality-fetch job locally or copying a readings.json file.
# LOCAL_READINGS_PATH=./tmp/air-quality

# ==============================================================================
# MONGODB (Optional — for dual-write migration)
# ==============================================================================
# When set, enables dual-write to both Firestore and MongoDB.
# See docs/features/database-layer.md for details.

# MongoDB connection string
# MONGODB_URI=mongodb://localhost:27017

# MongoDB database name (default: oboapp)
# MONGODB_DATABASE=oboapp

# Which database to read from: "firestore" or "mongodb" (default: firestore)
# DB_READ_SOURCE=firestore
