{
  "name": "oboapp-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/serve.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths && node build-vercel.mjs",
    "start": "node dist/serve.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@hono/node-server": "^1.19.9",
    "@oboapp/db": "workspace:*",
    "@oboapp/shared": "workspace:*",
    "@sentry/node": "^10.48.0",
    "@turf/center": "^7.3.1",
    "@turf/helpers": "^7.3.4",
    "@turf/turf": "^7.3.1",
    "firebase-admin": "^13.6.0",
    "hono": "^4.7.12",
    "openapi3-ts": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.0.18",
    "esbuild": "^0.27.4",
    "eslint": "^9.18.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.15"
  }
}
