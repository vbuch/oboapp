# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is git-ignored for security

project_id         = "your-project-id"
firebase_project_id = "your-firebase-project-id"  # Often same as project_id
region             = "europe-west1"
app_url            = "https://your-domain.com"

# Optional overrides
# image_tag = "v1.0.0"
# schedule_timezone = "UTC"

# GCS bucket for general-purpose file storage (leave empty to disable)
# gcs_generic_bucket = "your-project-gcs-bucket"

# Sentry DSN secret name in Secret Manager (leave empty to disable Sentry)
# First create the secret: gcloud secrets create sentry-dsn --replication-policy=automatic
# Then add the value:      gcloud secrets versions add sentry-dsn --data-file=<(echo -n "https://...@sentry.io/...")
# sentry_dsn_secret_id = "sentry-dsn"

# Customize schedules (cron format: minute hour day month weekday)
# Examples:
#   "0 6 * * *"   - Daily at 6:00 AM
#   "0 6 * * 1"   - Weekly on Mondays at 6:00 AM
#   "0 */6 * * *" - Every 6 hours
#   "30 8 * * 1-5" - Weekdays at 8:30 AM
#
# schedules = {
#   pipeline_emergent           = "*/30 7-22 * * *"
#   pipeline_all                = "0 10,14,16 * * *"
#   gtfs_sync                   = "0 3 * * *"
#   educational_facilities_sync = "0 4 1 * *"
#   air_quality_fetch           = "*/15 * * * *"
#   geocode_cache_report        = "0 5 * * 1"
#   heatmap_report              = "0 4 * * 1"
#   heartbeat_check             = "30 17 * * *"
# }
