# ==============================================================================
# PRODUCTION: Firebase & External APIs
# ==============================================================================
# For local development without cloud dependencies, use .env.example.emulator
# See docs/setup/production-setup.md for full setup instructions

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Gemini AI API Key
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Google Gemini AI Model
GOOGLE_AI_MODEL=gemini-2.5-flash-lite

# Google Gemini Embedding Model (optional, default: gemini-embedding-001)
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id

# Firebase Admin SDK Service Account
# Paste the entire JSON content from your service account key file as a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# App URL for notification links and images
APP_URL=https://oboapp.online

# ==============================================================================
# OPTIONAL SETTINGS
# ==============================================================================

# Locality identifier (required, no default)
# LOCALITY=bg.sofia

# Sentry DSN for error monitoring (optional — omit to disable Sentry entirely)
# When set, all logger.error() calls and unhandled exceptions are sent to Sentry.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Firebase Database ID (leave unset to use default database)
# FIREBASE_DATABASE_ID=oboapp-test

# ==============================================================================
# AIR QUALITY: Sensor Readings Storage
# ==============================================================================
# GCS bucket for general-purpose file storage (required in production)
# GCS_GENERIC_BUCKET=your-bucket-name

# Local filesystem path for readings in development (default: ./tmp/air-quality)
# LOCAL_READINGS_PATH=./tmp/air-quality

# ==============================================================================
# MONGODB (Optional — for dual-write migration)
# ==============================================================================
# When set, enables dual-write to both Firestore and MongoDB.
# See docs/features/database-layer.md for details.

# MongoDB connection string
# MONGODB_URI=mongodb://localhost:27017

# MongoDB database name (default: oboapp)
# MONGODB_DATABASE=oboapp

# Which database to read from: "firestore" or "mongodb" (default: firestore)
# DB_READ_SOURCE=firestore
