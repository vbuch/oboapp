{
  "name": "oboapp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build:shared": "pnpm --filter @oboapp/shared build",
    "build:db": "pnpm --filter @oboapp/db build",
    "build:api": "pnpm --filter oboapp-api build",
    "build:all": "pnpm build:shared && pnpm build:db && pnpm --filter oboapp-ingest build && pnpm --filter oboapp-api build && pnpm --filter oboapp-web build",
    "test:all": "pnpm -r --if-present run test:run",
    "test:coverage:sonar": "pnpm --filter oboapp-api test:coverage && pnpm --filter @oboapp/db test:coverage && pnpm --filter oboapp-ingest test:coverage && pnpm --filter @oboapp/shared test:coverage && pnpm --filter oboapp-web test:coverage",
    "lint:all": "pnpm -r --if-present run lint",
    "postinstall": "pnpm build:shared && pnpm build:db",
    "prepare": "husky",
    "apm:install": "apm install --force --verbose"
  },
  "devDependencies": {
    "@sentry/cli": "^3.3.5",
    "@types/node": "^20",
    "eslint": "^9.18.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.15"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.31.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@xmldom/xmldom": "^0.9.10",
      "@ungap/structured-clone": "^1.3.1",
      "basic-ftp": "^5.2.1"
    }
  }
}
